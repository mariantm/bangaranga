# =====================================================================
# Repository-wide .gitignore
# Per-module ignores can live in <module>/.gitignore if needed.
# =====================================================================

# --- OS / filesystem cruft ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# --- Editors / IDEs ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo
*~

# --- Java / Maven build output ---
target/
build/
out/
*.class

# --- Node / Angular ---
node_modules/
dist/
.angular/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Logs & diagnostic dumps ---
*.log
logs/
hs_err_pid*.log
replay_pid*.log

# --- Local Maven repo cache bundled with this project (NEVER push) ---
**/.m2verify-home/

# --- Secrets / local-only configuration ---
.env
.env.*
*.local.properties
application-local.properties
application-secrets.properties
application-*.local.properties
application.properties

# --- Claude Code local data (per-user / credentials) ---
.claude/settings.local.json
.claude/.credentials.json
.claude/memory/
# Team-shared Claude config (settings.json, agents/, skills/, commands/)
# is NOT ignored — remove the lines above if you also want those private.
